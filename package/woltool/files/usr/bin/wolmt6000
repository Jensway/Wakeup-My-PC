#!/bin/sh
# wolmt6000 - Wake-on-LAN 魔术包发送器（纯 Shell，无 Python 依赖）

[ -z "$1" ] && { echo "用法: wolmt6000 <MAC地址> [接口名]" >&2; exit 1; }

MAC="$1"
IFACE="$2"

# 清理 MAC 地址，去掉分隔符，转小写
mac=$(printf '%s' "$MAC" | tr -d ':-.' | tr 'A-F' 'a-f')
[ ${#mac} -ne 12 ] && { echo "MAC 地址格式不正确" >&2; exit 1; }

# 将 MAC 拆成 \xNN 格式
i=1; mf=""
while [ $i -le 11 ]; do
	mf="${mf}\\x$(echo "$mac" | cut -c${i}-$((i+1)))"
	i=$((i+2))
done

# 构造魔术包：6 字节 FF + MAC 重复 16 次
pkt="\\xff\\xff\\xff\\xff\\xff\\xff"
i=0; while [ $i -lt 16 ]; do pkt="${pkt}${mf}"; i=$((i+1)); done

# 写入临时文件（避免 shell 变量丢失二进制数据）
TMP=$(mktemp /tmp/wol.XXXXXX)
printf "${pkt}" > "$TMP"

# 获取接口定向广播地址
BRD=""
if [ -n "$IFACE" ]; then
	BRD=$(ip -o -4 addr show dev "$IFACE" 2>/dev/null | \
		awk '{for(i=1;i<=NF;i++)if($i=="brd"){print $(i+1);exit}}')
fi

# 向多个目标发送，提高可靠性
for dst in 255.255.255.255 ${BRD}; do
	for port in 7 9; do
		i=0; while [ $i -lt 3 ]; do
			cat "$TMP" | nc -u -w1 "$dst" "$port" 2>/dev/null &
			i=$((i+1))
		done
	done
done

wait 2>/dev/null
rm -f "$TMP"
echo "已发送魔术包至 $MAC"
