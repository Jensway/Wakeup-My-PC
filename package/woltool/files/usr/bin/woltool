#!/bin/sh

CONFIG="wolhost"

usage() {
	echo "用法:"
	echo "  woltool <主机名称>"
	echo "  woltool --mac <MAC地址> [接口名]"
	exit 1
}

# 发送唤醒包：优先 wolmt6000，回退 etherwake
do_wake() {
	local mac="$1"
	local iface="$2"

	if command -v wolmt6000 >/dev/null 2>&1; then
		echo "通过接口 $iface 唤醒 $mac (wolmt6000) ..."
		wolmt6000 "$mac" "$iface"
		return $?
	fi

	if command -v etherwake >/dev/null 2>&1; then
		echo "wolmt6000 不可用，通过接口 $iface 唤醒 $mac (etherwake) ..."
		etherwake -i "$iface" "$mac"
		return $?
	fi

	echo "错误: wolmt6000 和 etherwake 均不可用" >&2
	return 1
}

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
	usage
fi

if [ "$1" = "--mac" ]; then
	MAC="$2"
	IFACE="${3:-br-lan}"

	if [ -z "$MAC" ]; then
		usage
	fi

	do_wake "$MAC" "$IFACE"
	exit $?
fi

NAME="$1"

if [ -z "$NAME" ]; then
	usage
fi

SECTIONS=$(uci show "$CONFIG" 2>/dev/null | grep "=host" | cut -d'.' -f2 | cut -d'=' -f1)

if [ -z "$SECTIONS" ]; then
	echo "未找到任何主机配置，请编辑 /etc/config/$CONFIG" >&2
	exit 1
fi

for section in $SECTIONS; do
	sec_name=$(uci get "$CONFIG.$section.name" 2>/dev/null)
	mac=$(uci get "$CONFIG.$section.mac" 2>/dev/null)
	iface=$(uci get "$CONFIG.$section.iface" 2>/dev/null)

	[ -z "$iface" ] && iface="br-lan"

	if [ "$sec_name" = "$NAME" ]; then
		if [ -z "$mac" ]; then
			echo "配置错误: 主机 '$NAME' 没有 MAC" >&2
			exit 1
		fi
		do_wake "$mac" "$iface"
		exit $?
	fi
done

echo "未在 /etc/config/$CONFIG 中找到主机 '$NAME'" >&2
exit 1
